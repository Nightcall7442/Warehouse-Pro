# ============================================================
# Warehouse Pro — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# Railway MySQL: copy from Railway dashboard → MySQL service → Connect
DATABASE_URL=mysql://root:PASSWORD@HOST:PORT/railway

# ── APP SECURITY ─────────────────────────────────────────────
# Generate: openssl rand -base64 48
APP_SECRET=your-secret-key-here

# ── APP URL ──────────────────────────────────────────────────
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
PORT=3000

# ── CACHE (optional) ─────────────────────────────────────────
# CACHE_MAX_ENTRIES=500
# CACHE_DEFAULT_TTL_MS=60000

# ── RATE LIMITING (optional) ─────────────────────────────────
# RATE_LIMIT_GLOBAL_MAX=120
# RATE_LIMIT_WINDOW_MS=60000

# ── STRIPE (optional) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── SMTP (optional) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@warehousepro.app

# ── CRON (optional) ──────────────────────────────────────────
CRON_SECRET=random-secret

# ── TELEGRAM (optional) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── S3 / FILE STORAGE (optional, for logo uploads) ──────────
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ── 1C Bridge Service (optional) ────────────────────────────
ONEC_BRIDGE_URL=
ONEC_USERNAME=
ONEC_PASSWORD=
ONEC_WEBHOOK_SECRET=
